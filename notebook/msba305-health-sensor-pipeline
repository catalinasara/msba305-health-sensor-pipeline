ated quality report\n","# Report-friendly before vs after table for activity + weather sources\n","\n","def after_stats_activity(df: pd.DataFrame, name: str) -> dict:\n","    return {\n","        \"source\": name,\n","        \"n_files\": before_stats[name][\"n_files\"],\n","        \"n_rows\": int(len(df)),\n","        \"n_nulls\": int(df.isnull().sum().sum()),\n","        \"n_duplicates_composite_key\": int(df.duplicated(subset=[\"subject_id\", \"timestamp\"]).sum()),\n","        \"n_subjects\": int(df[\"subject_id\"].nunique()),\n","        \"subject_id_dtype\": str(df[\"subject_id\"].dtype),\n","        \"label_dtype\": str(df[\"label\"].dtype),\n","        \"activity_categories\": int(df[\"activity\"].nunique()),\n","        \"sampling_rate_hz\": TARGET_HZ,\n","        \"n_clipped_flag\": int(df[\"is_clipped\"].sum()),\n","        \"n_after_gap_flag\": int(df[\"after_gap\"].sum()),\n","    }\n","\n","after_harth = after_stats_activity(harth_df, \"HARTH\")\n","after_har70 = after_stats_activity(har70_df, \"HAR70+\")\n","\n","after_weather = {\n","    \"source\": \"Weather (Open-Meteo)\",\n","    \"n_rows\": int(len(weather_df)),\n","    \"n_nulls\": int(weather_df.isnull().sum().sum()),\n","    \"n_duplicates\": int(weather_df.duplicated().sum()),\n","    \"n_hours_expected\": int(len(pd.date_range(\n","        weather_df[\"weather_timestamp\"].min(),\n","        weather_df[\"weather_timestamp\"].max(),\n","        freq=\"h\"\n","    ))),\n","    \"hourly_grid_complete\": int(len(weather_df) == len(pd.date_range(\n","        weather_df[\"weather_timestamp\"].min(),\n","        weather_df[\"weather_timestamp\"].max(),\n","        freq=\"h\"\n","    ))),\n","    \"all_ranges_within_envelope\": True,\n","}\n","\n","# -------- formatting --------\n","def fmt_value(v):\n","    if v is None or (isinstance(v, float) and pd.isna(v)):\n","        return \"—\"\n","    if isinstance(v, (int, np.integer)):\n","        return f\"{v:,}\"\n","    if isinstance(v, float):\n","        return f\"{v:,.2f}\"\n","    if isinstance(v, bool):\n","        return \"Yes\" if v else \"No\"\n","    return str(v)\n","\n","# -------- metric definitions --------\n","activity_metrics = [\n","    (\"Files\", \"n_files\", \"n_files\"),\n","    (\"Rows\", \"n_rows\", \"n_rows\"),\n","    (\"Nulls (all columns)\", \"n_nulls\", \"n_nulls\"),\n","    (\"Exact duplicate rows\", \"n_duplicates\", None),\n","    (\"Duplicate (subject_id, timestamp)\", None, \"n_duplicates_composite_key\"),\n","    (\"Distinct schemas seen\", \"distinct_column_signatures\", None),\n","    (\"Subjects\", \"n_subjects\", \"n_subjects\"),\n","    (\"subject_id dtype\", \"subject_id_dtype_implied_by_filename\", \"subject_id_dtype\"),\n","    (\"label dtype\", \"label_dtypes_observed\", \"label_dtype\"),\n","    (\"Sampling rate (Hz)\", \"sampling_rates_hz_observed\", \"sampling_rate_hz\"),\n","    (\"Activity categories\", None, \"activity_categories\"),\n","    (\"Clipped-sample flag count\", None, \"n_clipped_flag\"),\n","    (\"Post-gap flag count\", None, \"n_after_gap_flag\"),\n","]\n","\n","weather_metrics = [\n","    (\"Raw hourly records\", \"n_hourly_records\", \"n_rows\"),\n","    (\"Nulls\", None, \"n_nulls\"),\n","    (\"Duplicate rows\", None, \"n_duplicates\"),\n","    (\"Expected hours in range\", None, \"n_hours_expected\"),\n","    (\"Hourly grid complete\", None, \"hourly_grid_complete\"),\n","    (\"All ranges valid\", None, \"all_ranges_within_envelope\"),\n","]\n","\n","# -------- build report tables --------\n","def build_before_after_df(source_name, before, after, metric_map):\n","    rows = []\n","    for label, b_key, a_key in metric_map:\n","        rows.append({\n","            \"Source\": source_name,\n","            \"Metric\": label,\n","            \"Before\": fmt_value(before.get(b_key) if b_key else None),\n","            \"After\": fmt_value(after.get(a_key) if a_key else None),\n","        })\n","    return pd.DataFrame(rows)\n","\n","report_harth = 