is visible and uncertainty\n","travels downstream."]},{"cell_type":"code","execution_count":35,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"j86gJRe8iAtL","executionInfo":{"status":"ok","timestamp":1777070534475,"user_tz":-180,"elapsed":3397,"user":{"displayName":"Charbel Fakhry","userId":"10313136220208256700"}},"outputId":"536b1a9c-6342-45dc-89bd-9bce5e9c170a"},"outputs":[{"output_type":"stream","name":"stdout","text":["============================================================\n","WINDOW CLASSIFICATION SUMMARY\n","============================================================\n","\n","By (session_id, date_validity):\n","session_id  date_validity  n_windows  n_subjects\n","    HAR70+           real      22355          18\n","  HARTH_S1 placeholder_s1      35598          14\n","  HARTH_S1           real       3684           1\n","  HARTH_S2 placeholder_s2      22718           7\n","\n","By weather_lookup_key:\n","weather_lookup_key\n","s1_bulk    35598\n","actual     26039\n","s2_bulk    22718\n"]}],"source":["## A. Classify each window by date validity\n","\n","PLACEHOLDER_S1_DATE = pd.Timestamp(\"2019-01-12\").date()\n","PLACEHOLDER_S2_DATE = pd.Timestamp(\"2000-01-01\").date()\n","\n","\n","def classify_window(row):\n","    src = row[\"source\"]\n","    sid = row[\"subject_id\"]\n","    d   = row[\"window_start\"].date()\n","\n","    if src == \"HAR70+\":\n","        return (\"HAR70+\", \"real\", \"actual\")\n","\n","    if src == \"HARTH\":\n","        if sid == \"S020\":\n","            return (\"HARTH_S1\", \"real\", \"actual\")\n","        if d == PLACEHOLDER_S1_DATE:\n","            return (\"HARTH_S1\", \"placeholder_s1\", \"s1_bulk\")\n","        if d == PLACEHOLDER_S2_DATE:\n","            return (\"HARTH_S2\", \"placeholder_s2\", \"s2_bulk\")\n","\n","    raise ValueError(\n","        f\"Unclassified window: subject_id={sid}, source={src}, date={d}.\"\n","    )\n","\n","\n","classification = windowed_df.apply(classify_window, axis=1, result_type=\"expand\")\n","classification.columns = [\"session_id\", \"date_validity\", \"weather_lookup_key\"]\n","windowed_df = pd.concat([windowed_df, classification], axis=1)\n","\n","assert windowed_df[\"weather_lookup_key\"].notna().all(), \"classification has NaNs\"\n","\n","print(\"=\" * 60)\n","print(\"WINDOW CLASSIFICATION SUMMARY\")\n","print(\"=\" * 60)\n","\n","summary = (\n","    windowed_df.groupby([\"session_id\", \"date_validity\"])\n","               .agg(n_windows=(\"window_start\", \"size\"),\n","                    n_subjects=(\"subject_id\", \"nunique\"))\n","               .reset_index()\n",")\n","print(\"\\nBy (session_id, date_validity):\")\n","print(summary.to_string(index=False))\n","\n","print(\"\\nBy weather_lookup_key:\")\n","print(windowed_df[\"weather_lookup_key\"].value_counts().to_string())"]},{"cell_type":"code","execution_count":36,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"HZOCLqaxiKzB","executionInfo":{"status":"ok","timestamp":1777070544724,"user_tz":-180,"elapsed":10216,"user":{"displayName":"Charbel Fakhry","userId":"10313136220208256700"}},"outputId":"7597dbd5-ca62-409b-8c3c-4f399c0e07b0"},"outputs":[{"output_type":"stream","name":"stdout","text":["✓ Row count preserved, no NaNs in weather columns\n","\n","============================================================\n","STRATIFIED JOIN — BREAKDOWN BY weather_source\n","============================================================\n","                n_windows  n_subjects  temp_min  temp_max  temp_mean\n","weather_source                                                      \n","actual              26039          19      0.50     22.90       7.33\n","climatology_s1      35598          14      2.45      2.45       2.45\n","climatology_s2      22718           7      4.60      4.60       4.60\n","\n","Total: 84,355 windows (58,316 imputed = 69.1%, 26,039 actual = 30.9%)\n","\n","S020 sanity check (real Mon 5 Dec 2016):\n","  n_windows:   3,684\n","  temperature: 1.6 → 2.0 °C\n","  source flag: ['actual']\n","\n","✓ Saved: /content/drive/MyDrive/Data Processing Project/Data/cleaned/windowed_weather.csv  (59.0 MB)\n","  Shape: (84355, 50)\n"]}],"source":["## B. Stratified weather attach + save\n","\n","NUMERIC_VARS = [\"temperature_c\", \"humidity_pct\", \"precipitation_mm\",\n","                \"wind_speed_kmh\", \"cloud_cover_pct\"]\n","WEATHER_VALUE_COLS = NUMERIC_VARS + [\"weather_code\"]\n","\n","\n","def stratified_weather_attach(windowed, weather_hourly, clim_table):\n","    parts = []\n","\n","    # --- Real-timestamp windows → hour-floor merge --------------------\n","    actual = windowed[windowed[\"weather_lookup_key\"] == \"actual\"].copy()\n","    actual[\"hour_key\"] = actual[\"window_start\"].dt.floor(\"h\")\n","\n","    wc = weather_hourly.copy()\n","    wc[\"hour_key\"] = wc[\"weather_timestamp\"]\n","\n","    actual = actual.merge(\n","        wc[[\"hour_key\"] + WEATHER_VALUE_COLS],\n","        on=\"hour_key\", how=\"left\",\n","    ).drop(columns=\"hour_key\")\n","\n","    for var in NUMERIC_VARS:\n","        actual[f\"{var}_std\"] = 0.0\n","    actual[\"weather_source\"] = \"actual\"\n","    parts.append(actual)\n","\n","    # --- Placeholder windows → climatology means+stds -----------------\n","    clim = clim_table.set_index(\"weather_lookup_key\")\n","\n","    for key in [\"s1_bulk\", \"s2_bulk\"]:\n","        subset = windowed[windowed[\"weather_lookup_key\"] == key].copy()\n","        if len(subset) == 0:\n","            continue\n","        prof = clim.loc[key]\n","        for var in NUMERIC_VARS:\n","            subset[var]          = float(prof[f\"{var}_mean\"])\n","            subset[f\"{var}_std\"] = float(prof[f\"{var}_std\"])\n","        subset[\"weather_code\"]   = int(prof[\"weather_code_mode\"])\n","        subset[\"weather_source\"] = f\"climatology_{key.split('_')[0]}\"\n","        parts.append(subset)\n","\n","    out = pd.concat(parts).sort_index()\n","    out[\"weather_is_imputed\"] = out[\"weather_source\"] != \"actual\"\n","    return out\n","\n","\n","windowed_weather = stratified_weather_attach(windowed_df, weather_df, climatology_table)\n","\n","# Validation\n","assert len(windowed_weather) == len(windowed_df), \"row count changed\"\n","for var in WEATHER_VALUE_COLS:\n","    assert windowed_weather[var].isna().sum() == 0, f\"{var} has NaN after attach\"\n","\n","print(\"✓ Row count preserved, no NaNs in weather columns\\n\")\n","\n","print(\"=\" * 60)\n","print(\"STRATIFIED JOIN — BREAKDOWN BY weather_source\")\n","print(\"=\" * 60)\n","src_summary = (\n","    windowed_weather.groupby(\"weather_source\")\n","    .agg(n_windows=(\"window_start\", \"size\"),\n","         n_subjects=(\"subject_id\", \"nunique\"),\n","         temp_min=(\"temperature_c\", \"min\"),\n","         temp_max=(\"temperature_c\", \"max\"),\n","         temp_mean=(\"temperature_c\", \"mean\"))\n","    .round(2)\n",")\n","print(src_summary.to_string())\n","\n","total = len(windowed_weather)\n","n_imp = int(windowed_weather[\"weather_is_imputed\"].sum())\n","print(f\"\\nTotal: {total:,} windows \"\n","      f\"({n_imp:,} imputed = {100*n_imp/total:.1f}%, \"\n","      f\"{total-n_imp:,} actual = {100*(total-n_imp)/total:.1f}%)\")\n","\n","# S020 sanity check\n","s020 = windowed_weather[windowed_weather[\"subject_id\"] == \"S020\"]\n","if len(s020) > 0:\n","    print(f\"\\nS020 sanity check (real Mon 5 Dec 2016):\")\n","    print(f\"  n_windows:   {len(s020):,}\")\n","    print(f\"  temperature: {s020['temperature_c'].min():.1f} → \"\n","          f\"{s020['temperature_c'].max():.1f} °C\")\n","    print(f\"  source flag: {s020['weather_source'].unique().tolist()}\")\n","\n","# Save\n","out_path = CLEAN_DIR / \"windowed_weather.csv\"\n","windowed_weather.to_csv(out_path, index=False)\n","size_mb = out_path.stat().st_size / 1e6\n","print(f\"\\n✓ Saved: {out_path}  ({size_mb:.1f} MB)\")\n","print(f\"  Shape: {windowed_weather.shape}\")"]},{"cell_type":"code","execution_count":37,"metadata":{"id":"0gnzlN0lh0Wg","executionInfo":{"status":"ok","timestamp":1777070544751,"user_tz":-180,"elapsed":25,"user":{"displayName":"Charbel Fakhry","userId":"10313136220208256700"}}},"outputs":[],"source":["## H. Handoff to Notebook 03\n","\n","# The windowed fact table is ready for:\n","#\n","#   Notebook 03 — Intensity calibration + MET enrichment\n","#     Computes intensity_percentile and adjusted_met per window.\n","#     Adds cal_per_kg = adjusted_met × (window_duration / 3600).\n","#\n","#   Notebook 04 — Storage load\n","#     Pushes fact table and dimensions into SQLite star schema.\n","#\n","#   Notebook 05 — Analytical queries\n","#     Runs the five Stage 7 queries against the schema."]},{"cell_type":"markdown","metadata":{"id":"HhjaH_rdh28Z"},"source":["\n","\n","Explicit handoff to the next stage. Each downstream notebook reads from windowed_2s.csv and produces a specific, documented output."]},{"cell_type":"markdown","metadata":{"id":"MFlyO16o0p_f"},"source":["## Section 4.4.3: Intensity Calibration & MET Enrichment\n","\n","Sensor standard deviation values are used to measure activity intensity for each time window.\n","Standard deviation captures exactly that pattern.\n","- A 2-second window of walking produces acceleration values that swing widely (high std).\n","- A 2-second window of sitting produces acceleration values that barely change (low std). Std is the single number that summarizes \"how much movement happened in this window.\"\n","\n","This notebook takes the windowed fact table produced by the previous step\n","and enriches it with three new columns that turn raw activity labels into\n","personalized, population-aware calorie rates:\n","\n","1. `intensity_percentile` — where each window's sensor std falls within its\n","   activity's overall distribution\n","2. `adjusted_met` — the base MET value from the Compendium, scaled by intensity\n","   percentile and cohort calibration\n","3. `cal_per_kg` — the weight-agnostic calorie rate per window\n","\n","## Relationship to other notebooks\n","- **Reads from:** `Data/cleaned/windowed_2s.csv`, `Data/met_lookup.csv`\n","- **Writes to:** `Data/cleaned/fact_activity_window.csv`\n","- **Consumed by:** `04_storage_load.ipynb`\n","\n","## Why this matters\n","The Compendium assigns a single MET value per activity — \"walking = 3.5\" —\n","regardless of who's walking or how briskly. This notebook fixes that:\n","it uses the sensor's std values to detect how vigorously each specific\n","window was performed, and adjusts MET up or down accordingly. It also\n","calibrates for the fact that HAR70+ participants produce measurably lower\n","sensor std for the same activity label — so the app gives cohort-appropriate\n","calorie estimates.\n","\n","\n","## Output\n","A fact table where each row represents one 2-second window, with everything\n","from `windowed_2s.csv` plus:\n","- `intensity_percentile` (0–100)\n","- `adjusted_met`\n","- `cal_per_kg` (weight-agnostic calorie rate)\n","\n","The fact table now holds a per-window calorie rate expressed in kcal per kg of body weight. No weight assumption is made anywhere in the pipeline. Weight is introduced only at application runtime."]},{"cell_type":"code","execution_count":38,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"1dsgeBjW1Xyd","executionInfo":{"status":"ok","timestamp":1777070546123,"user_tz":-180,"elapsed":1371,"user":{"displayName":"Charbel Fakhry","userId":"10313136220208256700"}},"outputId":"cccb0b09-c642-452d-c146-aa7afc3a950d"},"outputs":[{"output_type":"stream","name":"stdout","text":["Drive already mounted at /content/drive; to attempt to forcibly remount, call drive.mount(\"/content/drive\", force_remount=True).\n","Inputs:\n","  windowed: /content/drive/MyDrive/Data Processing Project/Data/cleaned/windowed_weather.csv\n","  MET:      /content/drive/MyDrive/Data Processing Project/Data/met_lookup.csv\n","\n","Output:   /content/drive/MyDrive/Data Processing Project/Data/cleaned/fact_activity_window.csv\n"]}],"source":["# Resolve DATA_PATH: Colab if available, otherwise local VS Code layout\n","try:\n","    from google.colab import drive\n","    drive.mount(\"/content/drive\")\n","    DATA_PATH = Path(\"/content/drive/MyDrive/Data Processing Project/Data\")\n","except (ImportError, ModuleNotFoundError):\n","    DATA_PATH = (Path.cwd() / \"..\" / \"Data\").resolve()\n","\n","CLEAN_DIR = DATA_PATH / \"cleaned\"\n","\n","# Inputs\n","WINDOWED_IN = CLEAN_DIR / \"windowed_weather.csv\"   # was: windowed_2s.csv\n","MET_LOOKUP  = DATA_PATH / \"met_lookup.csv\"\n","\n","# Output\n","FACT_OUT = CLEAN_DIR / \"fact_activity_window.csv\"\n","\n","# Sanity checks\n","assert WINDOWED_IN.exists(), f\"windowed_2s.csv not found — run 02_windowing first\"\n","assert MET_LOOKUP.exists(),  f\"met_lookup.csv not found — run 00_ingestion first\"\n","\n","print(f\"Inputs:\")\n","print(f\"  windowed: {WINDOWED_IN}\")\n","print(f\"  MET:      {MET_LOOKUP}\")\n","print(f\"\\nOutput:   {FACT_OUT}\")"]},{"cell_type":"markdown","metadata":{"id":"3_HDZhkt1aU-"},"source":["Resolves paths and verifies both inputs exist. The windowed fact table comes from Notebook 02, the MET lookup from Notebook 00."]},{"cell_type":"code","execution_count":39,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ygpP7krH1maL","executionInfo":{"status":"ok","timestamp":1777070547357,"user_tz":-180,"elapsed":1233,"user":{"displayName":"Charbel Fakhry","userId":"10313136220208256700"}},"outputId":"2a821795-ab22-4f5d-b819-f586b110cdac"},"outputs":[{"output_type":"stream","name":"stdout","text":["Loading windowed_weather.csv...\n"]},{"output_type":"stream","name":"stderr","text":["/tmp/ipykernel_11043/1780010314.py:5: DtypeWarning: Columns (0) have mixed types. Specify dtype option on import or set low_memory=False.\n","  df = pd.read_csv(WINDOWED_IN, parse_dates=[\"window_start\", \"window_end\"])\n"]},{"output_type":"stream","name":"stdout","text":["  windows: 84,355\n","  sources: ['HAR70+', 'HARTH']\n","  activities: 12\n","\n","Loading met_lookup.csv...\n","              activity  met_value  compendium_code  is_proxy  source\n","               sitting        1.0             7021     False scraped\n","                 lying        1.0             7011     False scraped\n","              standing        1.3             7040     False scraped\n","             shuffling        2.3            17151      True scraped\n","               walking        4.0            17255     False scraped\n","             stairs_up        4.5            17133     False scraped\n","           stairs_down        3.5            17070     False scraped\n","               running        9.3            12050     False scraped\n","           cycling_sit        6.8             1020     False scraped\n","         cycling_stand        7.0             1016     False scraped\n","  cycling_sit_inactive        1.0             7021      True scraped\n","cycling_stand_inactive        1.3             7040      True scraped\n"]}],"source":["## A. Load inputs\n","\n","# Load windowed fact table and MET lookup\n","print(\"Loading windowed_weather.csv...\")\n","df = pd.read_csv(WINDOWED_IN, parse_dates=[\"window_start\", \"window_end\"])\n","\n","# Re-enforce dtypes lost by CSV round-trip\n","df[\"subject_id\"] = df[\"subject_id\"].astype(str)\n","df[\"source\"]     = df[\"source\"].astype(str)\n","df[\"has_gap\"]    = df[\"has_gap\"].astype(bool)\n","\n","print(f\"  windows: {len(df):,}\")\n","print(f\"  sources: {df['source'].unique().tolist()}\")\n","print(f\"  activities: {df['activity'].nunique()}\")\n","\n","print(\"\\nLoading met_lookup.csv...\")\n","met_lookup = pd.read_csv(MET_LOOKUP)\n","print(met_lookup.to_string(index=False))"]},{"cell_type":"markdown","metadata":{"id":"5Pj_XgEM1q-t"},"source":["\n","\n","Loads the windowed fact table and the MET lookup. After this cell, the dataframe is ready for enrichment."]},{"cell_type":"code","execution_count":40,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"XjxZxcip1sxc","executionInfo":{"status":"ok","timestamp":1777070547408,"user_tz":-180,"elapsed":49,"user":{"displayName":"Charbel Fakhry","userId":"10313136220208256700"}},"outputId":"d1cf1415-435a-4a3e-fb3f-d53bf9a7eb20"},"outputs":[{"output_type":"stream","name":"stdout","text":["Intensity reference (p05, p50, p95 of thigh_z_std per cohort/activity):\n","source               activity    p05    p50    p95   mean  n_windows\n","HAR70+                  lying 0.0022 0.0072 0.0474 0.0132       2010\n","HAR70+              shuffling 0.0578 0.1332 0.2534 0.1415        544\n","HAR70+                sitting 0.0019 0.0077 0.0567 0.0156       4768\n","HAR70+            stairs_down 0.1411 0.2434 0.4556 0.2596         49\n","HAR70+              stairs_up 0.1762 0.2872 0.3688 0.2796         44\n","HAR70+               standing 0.0087 0.0236 0.1378 0.0405       4161\n","HAR70+                walking 0.1499 0.3416 0.6504 0.3651      10779\n"," HARTH            cycling_sit 0.1198 0.4482 1.0764 0.5281       3805\n"," HARTH   cycling_sit_inactive 0.0363 0.0855 0.4440 0.1425        366\n"," HARTH          cycling_stand 0.1211 0.3141 0.7390 0.3554        540\n"," HARTH cycling_stand_inactive 0.0461 0.0777 0.4600 0.1418         78\n"," HARTH                  lying 0.0016 0.0057 0.0341 0.0114       4141\n"," HARTH                running 0.7977 1.3468 1.8982 1.3385       2907\n"," HARTH              shuffling 0.0427 0.1663 0.4128 0.1887       2168\n"," HARTH                sitting 0.0011 0.0052 0.0448 0.0107      27648\n"," HARTH            stairs_down 0.3176 0.5203 0.9746 0.5674        691\n"," HARTH              stairs_up 0.2166 0.3519 0.7389 0.3965        786\n"," HARTH               standing 0.0055 0.0210 0.1870 0.0507       7085\n"," HARTH                walking 0.2137 0.6353 1.3317 0.6499      11785\n"]}],"source":["## B. Intensity calibration — per-activity, per-cohort percentiles\n","\n","# Decision: use thigh_z_std as the intensity signal.\n","# Why this axis: the up/down bounce of the thigh is the most informative\n","# single axis for movement intensity. Our EDA showed a 44% drop in\n","# thigh_z_std between HARTH and HAR70+ walking — the clearest cohort\n","# signal among all 6 axes.\n","\n","INTENSITY_COL = \"thigh_z_std\"\n","\n","# For each (cohort, activity) pair, compute the 5th and 95th percentile of\n","# the intensity signal. These define the range we map to the MET scaling band.\n","#\n","# Why percentiles, not min/max: raw min and max are unstable — a single\n","# unusual window can shift the extremes. Percentiles are robust.\n","\n","def compute_intensity_reference(df: pd.DataFrame, col: str) -> pd.DataFrame:\n","    \"\"\"Build a reference table of intensity percentiles per (cohort, activity).\"\"\"\n","    ref = df.groupby([\"source\", \"activity\"])[col].agg(\n","        p05=lambda x: x.quantile(0.05),\n","        p50=lambda x: x.quantile(0.50),\n","        p95=lambda x: x.quantile(0.95),\n","        mean=\"mean\",\n","        n_windows=\"count\",\n","    ).reset_index()\n","    return ref\n","\n","intensity_ref = compute_intensity_reference(df, INTENSITY_COL)\n","\n","print(f\"Intensity reference (p05, p50, p95 of {INTENSITY_COL} per cohort/activity):\")\n","print(intensity_ref.round(4).to_string(index=False))"]},{"cell_type":"markdown","metadata":{"id":"0eChxz411xAS"},"source":["Computes the 5th, 50th, and 95th percentiles of `thigh_z_std` for every (cohort, activity) combination. These percentiles define \"light,\" \"typical,\" and \"vigorous\" for each activity within each population. Because the reference is cohort-specific, HAR70+ gets its own scale — a HAR70+ window with std matching the HAR70+ median is \"typical HAR70+,\" not \"light HARTH.\""]},{"cell_type":"code","execution_count":41,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"BawOlZzA1-t6","executionInfo":{"status":"ok","timestamp":1777070550117,"user_tz":-180,"elapsed":2707,"user":{"displayName":"Charbel Fakhry","userId":"10313136220208256700"}},"outputId":"beaa0c78-f350-485b-cb82-2de756906990"},"outputs":[{"output_type":"stream","name":"stdout","text":["Computing intensity_percentile per window...\n","  intensity_percentile range: [0.0, 100.0]\n","  distribution summary:\n","count    84355.00\n","mean        49.99\n","std         28.87\n","min          0.00\n","25%         24.99\n","50%         49.99\n","75%         74.99\n","max        100.00\n"]}],"source":["## B.2 — Compute intensity percentile per window\n","\n","# For each window, compute where its thigh_z_std falls within its own\n","# (cohort, activity) distribution. Output: a value from 0 to 100.\n","\n","def compute_percentile(value, distribution):\n","    \"\"\"Return the percentile rank of `value` within `distribution` (0–100).\"\"\"\n","    return (distribution < value).mean() * 100\n","\n","# Build a dictionary for fast lookup of each (cohort, activity) distribution\n","print(\"Computing intensity_percentile per window...\")\n","distributions = {}\n","for (source, activity), group in df.groupby([\"source\", \"activity\"]):\n","    distributions[(source, activity)] = group[INTENSITY_COL].values\n","\n","# Vectorized percentile computation\n","# For each row, find the percentile of its intensity value within its group's distribution\n","def row_percentile(row):\n","    dist = distributions[(row[\"source\"], row[\"activity\"])]\n","    return (dist < row[INTENSITY_COL]).mean() * 100\n","\n","df[\"intensity_percentile\"] = df.apply(row_percentile, axis=1).round(2)\n","\n","print(f\"  intensity_percentile range: \"\n","      f\"[{df['intensity_percentile'].min():.1f}, {df['intensity_percentile'].max():.1f}]\")\n","print(f\"  distribution summary:\")\n","print(df[\"intensity_percentile\"].describe().round(2).to_string())"]},{"cell_type":"markdown","metadata":{"id":"_U93huqg2IvT"},"source":["Assigns every window an intensity percentile (0–100) within its own cohort-activity distribution. A percentile of 50 means the window's std matches the median for that activity in that cohort; 95 means it's in the top 5% of vigorous windows for that activity."]},{"cell_type":"code","execution_count":42,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"vmkgnudS2LAF","executionInfo":{"status":"ok","timestamp":1777070550633,"user_tz":-180,"elapsed":515,"user":{"displayName":"Charbel Fakhry","userId":"10313136220208256700"}},"outputId":"8f1d1970-4bd7-494c-873d-74d8f9b9c8df"},"outputs":[{"output_type":"stream","name":"stdout","text":["Merging base MET values...\n","  all 84,355 windows matched to a base MET value\n","\n","MET scaling applied:\n","  scale range:        [0.700, 1.550]\n","  base_met range:     [1.00, 9.30]\n","  adjusted_met range: [0.70, 14.41]\n","\n","Example enrichments (5 windows per activity):\n","source             activity  thigh_z_std  intensity_percentile  base_met  met_scale  adjusted_met\n","HAR70+             standing        0.044                 73.47       1.3      1.347         1.751\n","HAR70+             standing        0.010                  7.69       1.3      0.725         0.942\n","HAR70+            shuffling        0.147                 60.66       2.3      1.226         2.820\n","HAR70+            shuffling        0.141                 56.43       2.3      1.186         2.728\n","HAR70+              walking        0.128                  2.74       4.0      0.700         2.800\n","HAR70+              walking        0.266                 32.50       4.0      0.960         3.840\n","HAR70+              sitting        0.006                 34.27       1.0      0.976         0.976\n","HAR70+              sitting        0.006                 30.39       1.0      0.940         0.940\n","HAR70+                lying        0.020                 88.21       1.0      1.486         1.486\n","HAR70+                lying        0.036                 93.43       1.0      1.535         1.535\n","HAR70+          stairs_down        0.146                  6.12       3.5      0.711         2.488\n","HAR70+          stairs_down        0.153                 12.24       3.5      0.768         2.688\n","HAR70+            stairs_up        0.285                 45.45       4.5      1.082         4.869\n","HAR70+            stairs_up        0.369                 93.18       4.5      1.533         6.898\n"," HARTH          cycling_sit        0.367                 38.42       6.8      1.016         6.909\n"," HARTH          cycling_sit        0.116                  4.65       6.8      0.700         4.760\n"," HARTH cycling_sit_inactive        0.069                 36.34       1.0      0.996         0.996\n"," HARTH cycling_sit_inactive        0.098                 58.74       1.0      1.208         1.208\n"," HARTH        cycling_stand        0.358                 64.81       7.0      1.265         8.855\n"," HARTH        cycling_stand        0.292                 43.52       7.0      1.064         7.448\n"]}],"source":["## C. MET enrichment — look up base MET and scale by intensity\n","\n","# Join the MET lookup to assign a base MET per activity, then scale it by\n","# intensity_percentile.\n","\n","# Step 1: merge base MET values from the lookup\n","print(\"Merging base MET values...\")\n","df = df.merge(\n","    met_lookup[[\"activity\", \"met_value\"]].rename(columns={\"met_value\": \"base_met\"}),\n","    on=\"activity\",\n","    how=\"left\",\n",")\n","\n","# Verify every window got a MET value\n","n_missing = df[\"base_met\"].isnull().sum()\n","assert n_missing == 0, f\"MET lookup missing for {n_missing} windows — check activity names\"\n","print(f\"  all {len(df):,} windows matched to a base MET value\")\n","\n","# Step 2: scale MET by intensity percentile\n","# Mapping: percentile 50 → scale 1.0 (base MET unchanged)\n","#          percentile 5  → scale 0.7 (70% of base — the low-effort end)\n","#          percentile 95 → scale 1.3 (130% of base — the high-effort end)\n","# Linear interpolation between these anchors.\n","\n","MET_SCALE_MIN = 0.70  # scaling at percentile 5\n","MET_SCALE_MAX = 1.55  # scaling at percentile 95\n","\n","def percentile_to_scale(p):\n","    \"\"\"Linear map from percentile (0–100) to MET scaling factor (0.70–1.30).\"\"\"\n","    # Clamp into [5, 95] so extreme outlier windows don't produce implausible scales\n","    p_clamped = np.clip(p, 5, 95)\n","    # Linear interpolation between anchors\n","    return MET_SCALE_MIN + (MET_SCALE_MAX - MET_SCALE_MIN) * (p_clamped - 5) / (95 - 5)\n","\n","df[\"met_scale\"] = df[\"intensity_percentile\"].apply(percentile_to_scale).round(3)\n","df[\"adjusted_met\"] = (df[\"base_met\"] * df[\"met_scale\"]).round(3)\n","\n","print(f\"\\nMET scaling applied:\")\n","print(f\"  scale range:        [{df['met_scale'].min():.3f}, {df['met_scale'].max():.3f}]\")\n","print(f\"  base_met range:     [{df['base_met'].min():.2f}, {df['base_met'].max():.2f}]\")\n","print(f\"  adjusted_met range: [{df['adjusted_met'].min():.2f}, {df['adjusted_met'].max():.2f}]\")\n","\n","# Show a few example windows to make the transformation concrete\n","print(\"\\nExample enrichments (5 windows per activity):\")\n","sample = df.groupby(\"activity\").head(2)[\n","    [\"source\", \"activity\", \"thigh_z_std\", \"intensity_percentile\",\n","     \"base_met\", \"met_scale\", \"adjusted_met\"]\n","].round(3).head(20)\n","print(sample.to_string(index=False))"]},{"cell_type":"markdown","metadata":{"id":"4R8Q3iLN2bPt"},"source":["Merges base MET values from the Compendium lookup and scales each window's MET by its intensity percentile. The scaling band is ±30% — a window in the bottom 5% of its activity's intensity distribution gets 70% of base MET; a window in the top 5% gets 130%. This band is empirically reasonable: Compendium footnotes for \"walking\" span MET 2.5 (slow) to 5.0 (brisk), roughly ±40% of the canonical 3.5, so our ±30% band is slightly conservative.\n","\n","Note:\n","The base MET is the canonical value for the activity (walking = 3.5), assuming typical effort. The scale is a multiplier based on how vigorously this specific window was performed (0.70 to 1.30).\n","Multiplying adjusts the canonical value up or down:\n","\n","- Slow walking window (scale = 0.7): 3.5 × 0.7 = 2.45 MET → reflects a gentle stroll\n","- Brisk walking window (scale = 1.3): 3.5 × 1.3 = 4.55 MET → reflects a vigorous pace\n","- Average walking window (scale = 1.0): 3.5 × 1.0 = 3.5 MET → unchanged"]},{"cell_type":"code","execution_count":43,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"mEz1wpzO2dUg","executionInfo":{"status":"ok","timestamp":1777070550678,"user_tz":-180,"elapsed":26,"user":{"displayName":"Charbel Fakhry","userId":"10313136220208256700"}},"outputId":"a709fac1-64c3-4180-9f2f-d6da7d434d0d"},"outputs":[{"output_type":"stream","name":"stdout","text":["Calorie rate (cal_per_kg) computed:\n","count    84355.000000\n","mean         0.001563\n","std          0.001391\n","min          0.000385\n","25%          0.000608\n","50%          0.000838\n","75%          0.002321\n","max          0.007928\n","\n","Expected order of magnitude: ~0.001579 kcal/kg per window\n","(Given a typical MET of ~3 and 2-second windows)\n","\n","Sanity check: mean cal_per_kg per walking window = 0.002475\n","  → ~4.454 kcal/kg per hour of walking\n","  → ~311.8 kcal/hour for a 70kg user\n","  (Expected for brisk walking: 200–280 kcal/hour for a 70kg adult)\n"]}],"source":["## D. Calorie rate — weight-agnostic\n","\n","# Decision: compute calories per kg of body weight, NOT calories.\n","# The standard formula is:\n","#   calories = MET × weight_kg × duration_hours\n","# We store:\n","#   cal_per_kg = MET × duration_hours = calories / weight_kg\n","# The app multiplies by user-supplied weight at query time.\n","\n","# Convert window_duration from seconds to hours once\n","DURATION_SECONDS_TO_HOURS = 1 / 3600.0\n","\n","df[\"cal_per_kg\"] = (df[\"adjusted_met\"] * df[\"window_duration\"] * DURATION_SECONDS_TO_HOURS).round(6)\n","\n","print(f\"Calorie rate (cal_per_kg) computed:\")\n","print(df[\"cal_per_kg\"].describe().round(6).to_string())\n","\n","print(f\"\\nExpected order of magnitude: ~{df['adjusted_met'].mean() * 2 / 3600:.6f} kcal/kg per window\")\n","print(\"(Given a typical MET of ~3 and 2-second windows)\")\n","\n","# Sanity check: a 70kg user doing walking windows for an hour\n","# should burn roughly: 3.5 MET × 70 kg × 1 hr = 245 kcal\n","# Let's verify our numbers can reproduce this\n","walking = df[df[\"activity\"] == \"walking\"]\n","mean_cal_per_kg_per_window = walking[\"cal_per_kg\"].mean()\n","windows_per_hour = 3600 / 2  # 2-second windows\n","expected_cal_per_kg_per_hour = mean_cal_per_kg_per_window * windows_per_hour\n","expected_kcal_70kg_hour = expected_cal_per_kg_per_hour * 70\n","\n","print(f\"\\nSanity check: mean cal_per_kg per walking window = {mean_cal_per_kg_per_window:.6f}\")\n","print(f\"  → ~{expected_cal_per_kg_per_hour:.3f} kcal/kg per hour of walking\")\n","print(f\"  → ~{expected_kcal_70kg_hour:.1f} kcal/hour for a 70kg user\")\n","print(f\"  (Expected for brisk walking: 200–280 kcal/hour for a 70kg adult)\")"]},{"cell_type":"markdown","metadata":{"id":"5vFZ0olA3a9k"},"source":["Computes the weight-agnostic calorie rate per window using the standard MET formula with weight factored out: cal_per_kg = adjusted_met × (duration_seconds / 3600). Values are small per window (~0.002 kcal/kg) but sum up meaningfully across many windows. A sanity check reproduces the expected ~200–280 kcal/hour for walking at 70kg, confirming the math is right.\n","\n","Note on the sanity check:\n","We took the mean calorie rate across all walking windows to estimate a \"typical\" walking window. Then we scaled up: one hour = 1,800 windows of 2 seconds each. So:\n","\n","mean per window × 1,800 windows × 70 kg ≈ expected kcal/hour\n","\n","We used mean because we wanted a single \"representative\" number for walking — one value to extrapolate from. Could've used median instead; either works. The mean just tells us: \"on average, our walking windows produce X cal/kg, which scales to Y kcal per hour for a 70kg user.\"\n","The point wasn't statistical rigor — it was to check that the math produces ~200–280 kcal/hour (the published range for walking). If we got 20 kcal/hour or 2,000, something's wrong in the formula."]},{"cell_type":"code","execution_count":44,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"LnX6gasw3c5x","executionInfo":{"status":"ok","timestamp":1777070551447,"user_tz":-180,"elapsed":770,"user":{"displayName":"Charbel Fakhry","userId":"10313136220208256700"}},"outputId":"f3f29630-b408-45ec-9ae8-cc9fc7f8ae81"},"outputs":[{"output_type":"stream","name":"stdout","text":["Validating enriched fact table...\n","  ✓ Rule 1 (no nulls in enrichment columns)\n","  ✓ Rule 2 (intensity_percentile in [0, 100])\n","  ✓ Rule 3 (adjusted_met in plausible range)\n","  ✓ Rule 4 (cal_per_kg positive and per-window reasonable)\n","  ✓ Rule 5 (all 84,355 windows preserved)\n","\n","✓ All enrichment validation rules passed\n"]},{"output_type":"stream","name":"stderr","text":["/tmp/ipykernel_11043/1375888946.py:32: DtypeWarning: Columns (0) have mixed types. Specify dtype option on import or set low_memory=False.\n","  original_count = len(pd.read_csv(WINDOWED_IN))\n"]}],"source":["## E. Validation — enrichment invariants\n","\n","print(\"Validating enriched fact table...\")\n","\n","# Rule 1: every window has all three new columns populated\n","new_cols = [\"intensity_percentile\", \"adjusted_met\", \"cal_per_kg\"]\n","for c in new_cols:\n","    n_null = df[c].isnull().sum()\n","    assert n_null == 0, f\"  Rule 1 FAIL: {n_null} nulls in {c}\"\n","print(\"  ✓ Rule 1 (no nulls in enrichment columns)\")\n","\n","# Rule 2: intensity_percentile in [0, 100]\n","assert df[\"intensity_percentile\"].between(0, 100).all(), \\\n","    \"  Rule 2 FAIL: intensity_percentile outside [0, 100]\"\n","print(\"  ✓ Rule 2 (intensity_percentile in [0, 100])\")\n","\n","# Rule 3: adjusted_met within reasonable bounds\n","# Minimum: lying scaled down to 70% = 0.7 MET\n","# Maximum: cycling_stand scaled up to 130% = ~11 MET (generous upper bound)\n","assert df[\"adjusted_met\"].between(0.5, 15).all(), \\\n","    f\"  Rule 3 FAIL: adjusted_met outside [0.5, 15]: \" \\\n","    f\"min={df['adjusted_met'].min()}, max={df['adjusted_met'].max()}\"\n","print(\"  ✓ Rule 3 (adjusted_met in plausible range)\")\n","\n","# Rule 4: cal_per_kg positive and reasonable\n","assert (df[\"cal_per_kg\"] > 0).all(), \"  Rule 4 FAIL: non-positive cal_per_kg\"\n","assert df[\"cal_per_kg\"].max() < 0.01, \\\n","    f\"  Rule 4 FAIL: cal_per_kg too large for 2s window: max={df['cal_per_kg'].max()}\"\n","print(\"  ✓ Rule 4 (cal_per_kg positive and per-window reasonable)\")\n","\n","# Rule 5: window count preserved — enrichment shouldn't lose any rows\n","original_count = len(pd.read_csv(WINDOWED_IN))\n","assert len(df) == original_count, \\\n","    f\"  Rule 5 FAIL: row count changed from {original_count} to {len(df)}\"\n","print(f\"  ✓ Rule 5 (all {len(df):,} windows preserved)\")\n","\n","print(\"\\n✓ All enrichment validation rules passed\")"]},{"cell_type":"markdown","metadata":{"id":"odgMdOma3g_g"},"source":["Five invariants the enriched fact table must satisfy: no nulls in the new columns, percentile in valid range, MET and calorie rates in plausible physical bounds, and no rows lost during enrichment. Same fail-fast discipline used throughout the pipeline."]},{"cell_type":"code","execution_count":45,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"MsJhca9U3izH","executionInfo":{"status":"ok","timestamp":1777070551587,"user_tz":-180,"elapsed":139,"user":{"displayName":"Charbel Fakhry","userId":"10313136220208256700"}},"outputId":"66519691-36c3-426c-e637-9dccda7aa380"},"outputs":[{"output_type":"stream","name":"stdout","text":["=== Enriched fact table summary ===\n","\n","Intensity pe